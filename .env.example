# Supabase — get from https://supabase.com/dashboard/project/<project-ref>/settings/api
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# Google Gemini API — get from https://aistudio.google.com/app/apikey
# SECURITY: VITE_GEMINI_KEY is baked into the public JS bundle — anyone can extract it.
# Add HTTP referrer restrictions in Google Cloud Console: only allow salonai-app.netlify.app
# Consider moving ALL AI calls to Netlify Functions (server-side) to hide the key completely.
VITE_GEMINI_KEY=<your-gemini-api-key>
GEMINI_KEY=<your-gemini-api-key>

# Supabase Service Role Key (server-side only, never expose to browser)
# Used by Netlify Functions for admin DB operations
SUPABASE_SERVICE_KEY=<your-service-role-secret-key>

# Migration secret for /api/run-migration endpoint (pick a strong random string)
MIGRATION_SECRET=<strong-random-secret>

# Sentry error tracking — get DSN from sentry.io project settings
# Leave empty to disable (Sentry.init skips when DSN is not set)
VITE_SENTRY_DSN=
