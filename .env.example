# Supabase — get from https://supabase.com/dashboard/project/<project-ref>/settings/api
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# ── AI Provider ──────────────────────────────────────────────────────────────
# Default provider is DeepSeek. Set to "gemini" to switch back.
# VITE_AI_PROVIDER=deepseek

# DeepSeek API — https://platform.deepseek.com (recommended, OpenAI-compatible)
# SECURITY: VITE_DEEPSEEK_API_KEY is baked into the public JS bundle.
# Restrict key usage by HTTP referrer in DeepSeek dashboard if possible.
VITE_DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_API_KEY=<your-deepseek-api-key>

# Google Gemini API — fallback option, get from https://aistudio.google.com/app/apikey
# Set VITE_AI_PROVIDER=gemini and AI_PROVIDER=gemini to activate Gemini.
VITE_GEMINI_KEY=<your-gemini-api-key>
GEMINI_KEY=<your-gemini-api-key>

# Supabase Service Role Key (server-side only, never expose to browser)
# Used by Netlify Functions for admin DB operations
SUPABASE_SERVICE_KEY=<your-service-role-secret-key>

# Migration secret for /api/run-migration endpoint (pick a strong random string)
MIGRATION_SECRET=<strong-random-secret>

# Sentry error tracking — get DSN from sentry.io project settings
# Leave empty to disable (Sentry.init skips when DSN is not set)
VITE_SENTRY_DSN=
