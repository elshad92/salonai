# Server-side env vars for Netlify Functions (no VITE_ prefix!)
# Add these in Netlify Dashboard → Site settings → Environment variables

# Supabase (same URL as frontend, but use the SERVICE ROLE key for server writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...   # Settings → API → service_role key (keep secret!)

# Gemini AI (same key, server-side name)
GEMINI_KEY=AIzaSy...

# Optional: fallback Twilio for global use (per-salon creds are stored in DB)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
